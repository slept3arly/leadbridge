generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SALES
}

enum SalesPrivilege {
  JUNIOR
  SENIOR
}

enum LeadStatus {
  NEW
  CONVERTED
  LOST
  SPAM
  ON_HOLD
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  UPDATED
  ASSIGNED
  NOTE_ADDED
  NOTE_EDITED
  IMPORTED
  STATUS_CHANGED
  FOLLOW_UP
  DELETED
  RESTORED
  ATTACHMENT_ADDED
}

enum LeadCategory {
  MEDICAL_REPRESENTATIVE
  RETAILER
  WHOLESALER
  DISTRIBUTOR
  MARKETING
  THIRD_PARTY
  DOCTOR
  FRANCHISE
  BUSINESS
  HOSPITAL
  CLINIC
  PHARMACY
  LABORATORY
  MANUFACTURER
  CORPORATE
  GOVERNMENT
  OTHER
}

enum ConnectorStatus {
  INACTIVE
  ACTIVE
  ERROR
}

enum ConnectorScheduleType {
  MANUAL
  EVERY_5_MIN
  EVERY_15_MIN
  EVERY_30_MIN
  HOURLY
  DAILY
  CUSTOM
}

enum ConnectorHealthStatus {
  HEALTHY
  WARNING
  ERROR
}

enum UnmatchedEmailStatus {
  UNMATCHED
  ASSIGNED
  IGNORED
  SPAM
  PARSER_REQUESTED
}

enum ParserRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DECLINED
}

model User {
  id                     String           @id @default(cuid())
  name                   String
  email                  String           @unique
  emailVerified          Boolean          @default(false)
  image                  String?
  role                   UserRole         @default(SALES)
  salesPrivilege         SalesPrivilege?
  active                 Boolean          @default(true)
  banned                 Boolean          @default(false)
  banReason              String?
  banExpires             DateTime?
  phone                  String?
  employeeCode           String?          @unique
  designation            String?
  lastLoginAt            DateTime?
  lastSeenAt             DateTime?
  createdById            String?
  createdBy              User?            @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers           User[]           @relation("UserCreatedBy")
  deletedAt              DateTime?
  isDeleted              Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  accounts               Account[]
  sessions               Session[]
  assignedLeads          Lead[]           @relation("AssignedLeads")
  createdLeads           Lead[]           @relation("LeadCreatedBy")
  updatedLeads           Lead[]           @relation("LeadUpdatedBy")
  deletedLeads           Lead[]           @relation("LeadDeletedBy")
  activities             LeadActivity[]   @relation("ActivityActor")
  notes                  Note[]
  followUps              FollowUp[]       @relation("FollowUpAssignee")
  createdFollowUps       FollowUp[]       @relation("FollowUpCreator")
  uploadedAttachments    Attachment[]
  auditLogs              AuditLog[]
  updatedSettings        Setting[]
  handledUnmatchedEmails UnmatchedEmail[] @relation("UnmatchedEmailHandler")
  parserRequests         ParserRequest[]  @relation("ParserRequestRequester")

  @@index([role, active, isDeleted])
  @@index([isDeleted, deletedAt])
  @@map("users")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, providerId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model LeadSource {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  sourceType      String           @map("type")
  active          Boolean          @default(true)
  description     String?
  icon            String?
  color           String?
  priority        Int              @default(0)
  connectors      Connector[]
  leads           Lead[]
  routingRules    RoutingRule[]
  unmatchedEmails UnmatchedEmail[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([active, priority])
}

model Lead {
  id                String         @id @default(cuid())
  leadNumber        String         @unique @default(cuid())
  displayName       String         @map("name")
  company           String?
  email             String?
  phone             String?
  alternatePhone    String?
  address           String?
  city              String?
  state             String?
  country           String?
  product           String?
  requirement       String?
  industry          String?
  website           String?
  jobTitle          String?
  budget            Decimal?       @db.Decimal(14, 2)
  expectedValue     Decimal?       @db.Decimal(14, 2)
  currency          String?        @db.VarChar(3)
  campaign          String?
  campaignId        String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  utmTerm           String?
  firstContactedAt  DateTime?
  lastContactedAt   DateTime?
  nextFollowUpAt    DateTime?
  closedAt          DateTime?
  convertedAt       DateTime?
  lostReason        String?
  wonAmount         Decimal?       @db.Decimal(14, 2)
  sourceReferenceId String?
  sourceName        String?
  sourceType        String?
  parserVersion     String?
  receivedAt        DateTime?
  importedAt        DateTime?
  status            LeadStatus       @default(NEW)
  priority          LeadPriority     @default(MEDIUM)
  category          LeadCategory?
  lastFollowUpAt    DateTime?
  customFields      Json?
  rawPayload        Json?
  sourceId          String?
  connectorId       String?
  source            LeadSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  connector         Connector?     @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  assignedUserId    String?
  assignedUser      User?          @relation("AssignedLeads", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdById       String?
  createdBy         User?          @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById       String?
  updatedBy         User?          @relation("LeadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedById       String?
  deletedBy         User?          @relation("LeadDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  isArchived        Boolean        @default(false)
  isDeleted         Boolean        @default(false)
  deletedAt         DateTime?
  activities        LeadActivity[]
  notes             Note[]
  followUps         FollowUp[]
  attachments       Attachment[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([assignedUserId, status, isDeleted])
  @@index([status, isArchived, isDeleted])
  @@index([nextFollowUpAt, isDeleted])
  @@index([connectorId, sourceId])
  @@index([connectorId, sourceReferenceId])
  @@unique([connectorId, sourceReferenceId])
  @@index([createdById, createdAt])
  @@index([email])
  @@index([phone])
}

model LeadActivity {
  id        String       @id @default(cuid())
  type      ActivityType
  message   String
  metadata  Json?
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())

  @@index([leadId, createdAt])
  @@index([leadId, type, createdAt])
}

model Note {
  id               String     @id @default(cuid())
  content          String
  whatIDid         String?
  whatCustomerSaid String?
  leadId           String
  lead             Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId         String
  author           User       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  editedAt         DateTime   @updatedAt
  isPinned         Boolean    @default(false)
  visibility       String     @default("INTERNAL")
  followUps        FollowUp[]
  createdAt        DateTime   @default(now())

  @@index([leadId, createdAt])
  @@index([leadId, isPinned])
}

model FollowUp {
  id          String           @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?
  priority    FollowUpPriority @default(MEDIUM)
  status      FollowUpStatus   @default(PENDING)
  leadId      String
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  noteId      String?
  note        Note?            @relation(fields: [noteId], references: [id], onDelete: SetNull)
  assignedUserId String?
  assignedUser   User?         @relation("FollowUpAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User             @relation("FollowUpCreator", fields: [createdById], references: [id], onDelete: Restrict)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([leadId, dueDate, status])
  @@index([assignedUserId, status, dueDate])
  @@index([leadId, createdAt])
}

model Attachment {
  id              String   @id @default(cuid())
  name            String
  key             String
  mimeType        String
  size            Int
  checksum        String?
  storageProvider String   @default("local")
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadedById    String?
  uploadedBy      User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([checksum])
}

model Connector {
  id                  String                @id @default(cuid())
  name                String                @unique
  environmentKey      String?               @unique
  type                String
  enabled             Boolean               @default(false)
  status              ConnectorStatus       @default(INACTIVE)
  configuration       Json?
  runtimeMetadata     Json?
  lastSyncedAt        DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastError           String?
  pollInterval        Int?
  scheduleType        ConnectorScheduleType @default(MANUAL)
  scheduleConfig      Json?
  nextScheduledRun    DateTime?
  consecutiveFailures Int                   @default(0)
  averageDurationMs   Int?
  lastDurationMs      Int?
  healthStatus        ConnectorHealthStatus @default(HEALTHY)
  isRunning           Boolean               @default(false)
  lockedAt            DateTime?
  lockedBy            String?
  sourceId            String?
  source              LeadSource?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  parserId            String?
  parser              Parser?               @relation(fields: [parserId], references: [id], onDelete: SetNull)
  fieldMappings       FieldMapping[]
  leads               Lead[]
  syncRuns            ConnectorSyncRun[]
  routingRules        RoutingRule[]
  unmatchedEmails     UnmatchedEmail[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([enabled, status])
  @@index([sourceId, enabled])
  @@index([parserId])
}

model Parser {
  id            String        @id @default(cuid())
  name          String        @unique
  type          String
  version       String?
  description   String?
  configuration Json?
  active        Boolean       @default(true)
  connectors    Connector[]
  routingRules  RoutingRule[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([type, active])
}

model ConnectorSyncRun {
  id             String          @id @default(cuid())
  connectorId    String
  connector      Connector       @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  status         ConnectorStatus
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  recordsSeen    Int             @default(0)
  recordsCreated Int             @default(0)
  recordsUpdated Int             @default(0)
  recordsSkipped Int             @default(0)
  errorMessage   String?
  metadata       Json?

  @@index([connectorId, startedAt])
  @@index([status, startedAt])
}

model RoutingRule {
  id                    String     @id @default(cuid())
  name                  String
  recipientGmailAccount String?
  senderEmail           String?
  senderDomain          String?
  subjectContains       String?
  gmailLabel            String?
  priority              Int        @default(100)
  fallback              Boolean    @default(false)
  active                Boolean    @default(true)
  providerId            String
  provider              LeadSource @relation(fields: [providerId], references: [id], onDelete: Cascade)
  parserId              String
  parser                Parser     @relation(fields: [parserId], references: [id], onDelete: Restrict)
  connectorId           String?
  connector             Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([active, priority])
  @@index([recipientGmailAccount, active, priority])
  @@index([providerId])
}

model UnmatchedEmail {
  id              String               @id @default(cuid())
  senderEmail     String
  subject         String?
  receivedAt      DateTime
  rawPreview      String?
  status          UnmatchedEmailStatus @default(UNMATCHED)
  connectorId     String?
  connector       Connector?           @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  providerId      String?
  provider        LeadSource?          @relation(fields: [providerId], references: [id], onDelete: SetNull)
  rawPayload      Json?
  handledById     String?
  handledBy       User?                @relation("UnmatchedEmailHandler", fields: [handledById], references: [id], onDelete: SetNull)
  handledAt       DateTime?
  parserRequestId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status, receivedAt])
  @@index([connectorId, receivedAt])
  @@index([senderEmail])
}

model ParserRequest {
  id             String              @id @default(cuid())
  vendorName     String
  senderEmail    String
  sampleSubject  String?
  samplePreview  String?
  requestedById  String
  requestedBy    User                @relation("ParserRequestRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  requestedAt    DateTime            @default(now())
  status         ParserRequestStatus @default(OPEN)
  developerNotes String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, requestedAt])
  @@index([requestedById, requestedAt])
}

model FieldMapping {
  id          String     @id @default(cuid())
  sourceField String
  targetField String
  transform   String?
  connectorId String?
  connector   Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([connectorId, sourceField])
  @@index([connectorId, targetField])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  requestId  String?
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([requestId])
  @@index([actorId, createdAt])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  category    String?
  description String?
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}
