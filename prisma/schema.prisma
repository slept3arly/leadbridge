generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  UPDATED
  ASSIGNED
  NOTE_ADDED
  IMPORTED
  STATUS_CHANGED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  emailVerified Boolean        @default(false)
  image         String?
  role          String         @default("SALES")
  active        Boolean        @default(true)
  banned        Boolean        @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  assignedLeads Lead[]         @relation("AssignedLeads")
  activities    LeadActivity[] @relation("ActivityActor")
  notes         Note[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String   @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model LeadSource {
  id          String      @id @default(cuid())
  name        String      @unique
  type        String
  active      Boolean     @default(true)
  description String?
  connectors  Connector[]
  leads       Lead[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Lead {
  id                String         @id @default(cuid())
  name              String
  company           String?
  email             String?
  phone             String?
  alternatePhone    String?
  address           String?
  city              String?
  state             String?
  country           String?
  product           String?
  requirement       String?
  sourceReferenceId String?
  status            LeadStatus     @default(NEW)
  priority          LeadPriority   @default(MEDIUM)
  customFields      Json?
  sourceId          String?
  connectorId       String?
  source            LeadSource?    @relation(fields: [sourceId], references: [id])
  connector         Connector?     @relation(fields: [connectorId], references: [id])
  assignedUserId    String?
  assignedUser      User?          @relation("AssignedLeads", fields: [assignedUserId], references: [id])
  activities        LeadActivity[]
  notes             Note[]
  attachments       Attachment[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([assignedUserId, status])
  @@index([connectorId, sourceId])
  @@index([email])
  @@index([phone])
}

model LeadActivity {
  id        String       @id @default(cuid())
  type      ActivityType
  message   String
  metadata  Json?
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?        @relation("ActivityActor", fields: [actorId], references: [id])
  createdAt DateTime     @default(now())

  @@index([leadId, createdAt])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  key       String
  mimeType  String
  size      Int
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Connector {
  id            String         @id @default(cuid())
  name          String         @unique
  type          String
  enabled       Boolean        @default(false)
  configuration Json?
  lastSyncedAt  DateTime?
  sourceId      String?
  source        LeadSource?    @relation(fields: [sourceId], references: [id])
  fieldMappings FieldMapping[]
  leads         Lead[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Parser {
  id            String   @id @default(cuid())
  name          String   @unique
  type          String
  configuration Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FieldMapping {
  id          String     @id @default(cuid())
  sourceField String
  targetField String
  transform   String?
  connectorId String?
  connector   Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([connectorId, sourceField])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
